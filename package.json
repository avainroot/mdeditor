    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "rollup-plugin-visualizer": "^7.0.0",
    "sass": "^1.97.3",
    "sass-embedded": "^1.97.3",
    "tailwindcss": "^4.2.1",
